generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────
enum UserRole {
  ADMIN
  AGENT
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  REJECTED
}

enum GroupCategory {
  UMRAH
  UAE_ONE_WAY
  KSA_ONE_WAY
  OMAN_ONE_WAY
  UK_ONE_WAY
}

enum GroupStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
}

enum BookingStatus {
  ON_REQUEST
  PARTIAL
  CONFIRMED
  CANCELLED
}

enum BookingType {
  AIRLINE
  PACKAGE
  UMRAH_CALCULATOR
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

enum PaymentStatus {
  POSTED
  UNPOSTED
}

enum HotelCity {
  MAKKAH
  MADINA
}

enum RoomType {
  PRIVATE
  SHARING
}

// ─── USERS / AGENTS ──────────────────────────────────
model User {
  id            Int        @id @default(autoincrement())
  agentCode     String?    @unique @map("agent_code")
  agencyName    String     @map("agency_name")
  contactPerson String     @map("contact_person")
  email         String     @unique
  password      String
  phone         String?
  city          String?
  country       String?    @default("Pakistan")
  logoUrl       String?    @map("logo_url")
  role          UserRole   @default(AGENT)
  status        UserStatus @default(PENDING)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  bookings      Booking[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]

  @@map("users")
}

// ─── AIRLINES ────────────────────────────────────────
model Airline {
  id       Int     @id @default(autoincrement())
  name     String
  logoUrl  String? @map("logo_url")
  isActive Boolean @default(true) @map("is_active")

  flightGroups FlightGroup[]

  @@map("airlines")
}

// ─── SECTORS / ROUTES ────────────────────────────────
model Sector {
  id           Int     @id @default(autoincrement())
  origin       String
  destination  String
  routeDisplay String  @map("route_display")
  isRoundTrip  Boolean @default(false) @map("is_round_trip")

  flightGroups FlightGroup[]

  @@map("sectors")
}

// ─── FLIGHT GROUPS ───────────────────────────────────
model FlightGroup {
  id             Int           @id @default(autoincrement())
  groupName      String        @map("group_name")
  category       GroupCategory
  airlineId      Int           @map("airline_id")
  sectorId       Int           @map("sector_id")
  totalSeats     Int           @map("total_seats")
  availableSeats Int           @map("available_seats")
  departureDate  DateTime      @map("departure_date") @db.Date
  returnDate     DateTime?     @map("return_date") @db.Date
  numDays        Int?          @map("num_days")
  adultPrice     Decimal       @map("adult_price") @db.Decimal(12, 2)
  childPrice     Decimal?      @map("child_price") @db.Decimal(12, 2)
  infantPrice    Decimal?      @map("infant_price") @db.Decimal(12, 2)
  currency       String        @default("PKR")
  pnr1           String?       @map("pnr_1")
  pnr2           String?       @map("pnr_2")
  status         GroupStatus   @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  airline    Airline     @relation(fields: [airlineId], references: [id])
  sector     Sector      @relation(fields: [sectorId], references: [id])
  flightLegs FlightLeg[]
  bookings   Booking[]
  packages   UmrahPackage[]

  @@map("flight_groups")
}

// ─── FLIGHT LEGS / SEGMENTS ──────────────────────────
model FlightLeg {
  id            Int      @id @default(autoincrement())
  groupId       Int      @map("group_id")
  legNumber     Int      @map("leg_number")
  flightNumber  String   @map("flight_number")
  departureDate DateTime @map("departure_date") @db.Date
  origin        String
  destination   String
  departureTime String?  @map("departure_time")
  arrivalTime   String?  @map("arrival_time")
  baggage       String?

  group FlightGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("flight_legs")
}

// ─── BOOKINGS ────────────────────────────────────────
model Booking {
  id              Int           @id @default(autoincrement())
  bookingNo       String        @unique @map("booking_no")
  agentId         Int           @map("agent_id")
  groupId         Int?          @map("group_id")
  packageId       Int?          @map("package_id")
  bookingType     BookingType   @default(AIRLINE) @map("booking_type")
  roomType        String?       @map("room_type")
  adultsCount     Int           @map("adults_count")
  childrenCount   Int           @default(0) @map("children_count")
  infantsCount    Int           @default(0) @map("infants_count")
  totalSeats      Int           @map("total_seats")
  totalPrice      Decimal       @map("total_price") @db.Decimal(12, 2)
  status          BookingStatus @default(ON_REQUEST)
  expiryTime      DateTime?     @map("expiry_time")
  autoCancelledAt DateTime?     @map("auto_cancelled_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  agent      User          @relation(fields: [agentId], references: [id])
  group      FlightGroup?  @relation(fields: [groupId], references: [id])
  package    UmrahPackage? @relation(fields: [packageId], references: [id])
  passengers Passenger[]
  ledgerEntries LedgerEntry[]

  @@map("bookings")
}

// ─── PASSENGERS ──────────────────────────────────────
model Passenger {
  id         Int           @id @default(autoincrement())
  bookingId  Int           @map("booking_id")
  name       String
  type       PassengerType
  dob        DateTime?     @db.Date
  passportNo String?       @map("passport_no")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("passengers")
}

// ─── HOTELS ──────────────────────────────────────────
model Hotel {
  id           Int       @id @default(autoincrement())
  name         String
  city         HotelCity
  distance     Decimal?  @db.Decimal(8, 2)
  starRating   Int?      @map("star_rating")
  sharingRate  Decimal?  @map("sharing_rate") @db.Decimal(10, 2)
  doubleRate   Decimal?  @map("double_rate") @db.Decimal(10, 2)
  tripleRate   Decimal?  @map("triple_rate") @db.Decimal(10, 2)
  quadRate     Decimal?  @map("quad_rate") @db.Decimal(10, 2)
  quintRate    Decimal?  @map("quint_rate") @db.Decimal(10, 2)
  validFrom    DateTime? @map("valid_from") @db.Date
  validTo      DateTime? @map("valid_to") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  packageHotels PackageHotel[]

  @@map("hotels")
}

// ─── UMRAH PACKAGES ──────────────────────────────────
model UmrahPackage {
  id             Int         @id @default(autoincrement())
  packageName    String      @map("package_name")
  groupId        Int?        @map("group_id")
  numDays        Int?        @map("num_days")
  availableSeats Int?        @map("available_seats")
  sharedPrice    Decimal?    @map("shared_price") @db.Decimal(12, 2)
  doublePrice    Decimal?    @map("double_price") @db.Decimal(12, 2)
  triplePrice    Decimal?    @map("triple_price") @db.Decimal(12, 2)
  quadPrice      Decimal?    @map("quad_price") @db.Decimal(12, 2)
  departureDate  DateTime?   @map("departure_date") @db.Date
  returnDate     DateTime?   @map("return_date") @db.Date
  status         GroupStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  group         FlightGroup?  @relation(fields: [groupId], references: [id])
  packageHotels PackageHotel[]
  packageTransport PackageTransport?
  bookings      Booking[]

  @@map("umrah_packages")
}

// ─── PACKAGE HOTELS (Junction) ───────────────────────
model PackageHotel {
  id          Int       @id @default(autoincrement())
  packageId   Int       @map("package_id")
  hotelId     Int       @map("hotel_id")
  city        HotelCity
  nights      Int
  checkinDate DateTime? @map("checkin_date") @db.Date
  checkoutDate DateTime? @map("checkout_date") @db.Date
  sequence    Int       @default(1)

  package UmrahPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  hotel   Hotel        @relation(fields: [hotelId], references: [id])

  @@map("package_hotels")
}

// ─── PACKAGE TRANSPORT ───────────────────────────────
model PackageTransport {
  id          Int    @id @default(autoincrement())
  packageId   Int    @unique @map("package_id")
  transportId Int    @map("transport_id")
  cost        Decimal? @db.Decimal(10, 2)

  package   UmrahPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  transport Transport    @relation(fields: [transportId], references: [id])

  @@map("package_transports")
}

// ─── VISA TYPES ──────────────────────────────────────
model VisaType {
  id            Int      @id @default(autoincrement())
  name          String
  adultBuyRate  Decimal? @map("adult_buy_rate") @db.Decimal(10, 2)
  adultSellRate Decimal? @map("adult_sell_rate") @db.Decimal(10, 2)
  childBuyRate  Decimal? @map("child_buy_rate") @db.Decimal(10, 2)
  childSellRate Decimal? @map("child_sell_rate") @db.Decimal(10, 2)
  currency      String   @default("SAR")
  isActive      Boolean  @default(true) @map("is_active")

  @@map("visa_types")
}

// ─── TRANSPORT ───────────────────────────────────────
model Transport {
  id          Int      @id @default(autoincrement())
  vehicleType String   @map("vehicle_type")
  route       String?
  buyRate     Decimal? @map("buy_rate") @db.Decimal(10, 2)
  sellRate    Decimal? @map("sell_rate") @db.Decimal(10, 2)
  isActive    Boolean  @default(true) @map("is_active")

  packageTransports PackageTransport[]

  @@map("transports")
}

// ─── BANK ACCOUNTS ───────────────────────────────────
model BankAccount {
  id            Int      @id @default(autoincrement())
  bankName      String   @map("bank_name")
  accountTitle  String   @map("account_title")
  accountNumber String   @map("account_number")
  iban          String?
  branchAddress String?  @map("branch_address")
  logoUrl       String?  @map("logo_url")
  isActive      Boolean  @default(true) @map("is_active")

  payments Payment[]

  @@map("bank_accounts")
}

// ─── PAYMENTS ────────────────────────────────────────
model Payment {
  id            Int           @id @default(autoincrement())
  voucherId     String        @unique @map("voucher_id")
  agentId       Int           @map("agent_id")
  date          DateTime      @db.Date
  description   String?
  bankAccountId Int?          @map("bank_account_id")
  amount        Decimal       @db.Decimal(12, 2)
  receiptUrl    String?       @map("receipt_url")
  status        PaymentStatus @default(UNPOSTED)
  remarks       String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  agent       User         @relation(fields: [agentId], references: [id])
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  ledgerEntries LedgerEntry[]

  @@map("payments")
}

// ─── LEDGER ENTRIES ──────────────────────────────────
model LedgerEntry {
  id          Int      @id @default(autoincrement())
  voucherNo   String?  @map("voucher_no")
  agentId     Int      @map("agent_id")
  date        DateTime @db.Date
  description String?
  debit       Decimal  @default(0) @db.Decimal(12, 2)
  credit      Decimal  @default(0) @db.Decimal(12, 2)
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  bookingId   Int?     @map("booking_id")
  paymentId   Int?     @map("payment_id")
  createdAt   DateTime @default(now()) @map("created_at")

  agent   User     @relation(fields: [agentId], references: [id])
  booking Booking? @relation(fields: [bookingId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("ledger_entries")
}

// ─── OFFICE BRANCHES ─────────────────────────────────
model OfficeBranch {
  id       Int     @id @default(autoincrement())
  name     String
  city     String
  address  String
  imageUrl String? @map("image_url")
  isHead   Boolean @default(false) @map("is_head")
  isActive Boolean @default(true) @map("is_active")

  @@map("office_branches")
}

// ─── AUTHORIZATIONS / CERTIFICATIONS ─────────────────
model Authorization {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  logoUrl     String? @map("logo_url")
  isActive    Boolean @default(true) @map("is_active")

  @@map("authorizations")
}

// ─── DEALS / PROMOTIONS ──────────────────────────────
model Deal {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("deals")
}

// ─── COMPANY SETTINGS ────────────────────────────────
model CompanySetting {
  id            Int    @id @default(autoincrement())
  companyName   String @map("company_name")
  tagline       String?
  logoUrl       String? @map("logo_url")
  email         String?
  phone         String?
  whatsapp      String?
  address       String?
  facebookUrl   String? @map("facebook_url")
  instagramUrl  String? @map("instagram_url")
  twitterUrl    String? @map("twitter_url")
  youtubeUrl    String? @map("youtube_url")
  linkedinUrl   String? @map("linkedin_url")
  heroVideoUrl  String? @map("hero_video_url")
  heroImageUrl  String? @map("hero_image_url")

  @@map("company_settings")
}
